{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Truebases/truebases-mcp",
  "description": "Find opportunities, track market activity, and discover business signals with real-time data.",
  "repository": {
    "url": "https://github.com/Truebases/truebases-mcp",
    "source": "github"
  },
  "version": "1.0.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "truebases-mcp",
      "version": "1.0.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your API key for the TrueBases API",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "TRUEBASES_API_KEY"
        },
        {
          "description": "TrueBases API URL (optional)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "TRUEBASES_API_URL"
        }
      ]
    }
  ]
}